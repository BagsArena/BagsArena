    "metrics:arena": "node --env-file-if-exists=.env.local --env-file-if-exists=.env --import tsx src/scripts/arena-metrics.ts",
    "readiness:arena": "node --env-file-if-exists=.env.local --env-file-if-exists=.env --import tsx src/scripts/arena-readiness.ts"
  },
  "dependencies": {
    "@bagsfm/bags-sdk": "^1.3.1",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@solana/web3.js": "^1.98.4",
    "bullmq": "^5.71.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
